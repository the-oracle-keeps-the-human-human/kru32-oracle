---
import "../styles/input.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Kru32 Oracle — ESP32 Display Course Flasher",
  description = "Flash ESP32 JC3248W535 display lessons จากเบราว์เซอร์ — 16 บทเรียน ESPHome คอมไพล์ผ่านจริง",
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- ฟอนต์ self-host (JetBrains Mono + IBM Plex Sans Thai) — ไม่พึ่ง Google CDN -->
    <link rel="stylesheet" href={`${base}/fonts.css`} />
    <!-- esp-web-tools self-host: defines <esp-web-install-button> (flash flow) -->
    <script type="module" src={`${base}/vendor/esp-web-tools/install-button.js`}></script>
    <!-- Improv-Serial SDK self-host: defines <improv-wifi-serial-launch-button> (หน้า Config WiFi) -->
    <script type="module" src={`${base}/vendor/improv/serial-launch-button.js`}></script>
  </head>
  <body>
    <slot />
  </body>
</html>
