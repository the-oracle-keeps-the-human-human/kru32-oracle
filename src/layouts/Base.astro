---
import "../styles/input.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Kru32 Oracle — ESP32 Display Course Flasher",
  description = "Flash ESP32 JC3248W535 display lessons จากเบราว์เซอร์ — 16 บทเรียน ESPHome คอมไพล์ผ่านจริง",
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- ฟอนต์ self-host (JetBrains Mono + IBM Plex Sans Thai) — ไม่พึ่ง Google CDN -->
    <link rel="stylesheet" href={`${base}/fonts.css`} />
    <!-- esp-web-tools@10.2.1 (world latest) จาก unpkg — ตัวเต็ม พิสูจน์แล้ว flash ได้ไม่ crash
         (vendored self-host ที่เคยลอง chunk ไม่ครบ → flash เงียบ; unpkg เต็ม) -->
    <script type="module" src="https://unpkg.com/esp-web-tools@10.2.1/dist/web/install-button.js?module"></script>
    <!-- Improv-Serial SDK (unpkg) สำหรับหน้า /wifi (flash แล้ว improv ในตัวก็ได้เหมือนกัน) -->
    <script type="module" src="https://unpkg.com/improv-wifi-serial-sdk@2/dist/web/launch-button.js?module"></script>
  </head>
  <body>
    <slot />
  </body>
</html>
