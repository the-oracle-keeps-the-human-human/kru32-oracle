---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const asset = (p: string) => `${base}/${p}`;
---

<Base
  title="Lesson: erase:false — ทำไม Web Flasher crash เบราว์เซอร์"
  description="บทเรียนจริง: full-chip erase ทำ Chromium crash บน ESP32-S3 native USB — กด flash เทียบซ้ายขวาได้"
>
  <div class="relative max-w-[1080px] mx-auto px-6 py-10 pb-16">
    <a href={`${base}/`} class="font-display text-[11px] text-[#f6c544] hover:underline">← กลับหน้ารวมบท</a>

    <header class="mt-5 text-center">
      <div class="font-display text-[11px] tracking-[.25em] uppercase text-[#f6c544]">Lesson Learned</div>
      <h1 class="font-display text-[2rem] md:text-[2.4rem] font-bold text-[#f4efe0] mt-1 [text-shadow:0_2px_28px_rgba(246,197,68,.3)]">
        Flag ที่ทำเบราว์เซอร์ crash ได้ (บาง Chromium / บางจังหวะ)
      </h1>
      <p class="text-[#c9bfa6] text-sm mt-3 max-w-2xl mx-auto leading-relaxed">
        Web flasher ตัวเดียวกัน · esp-web-tools เวอร์ชันเดียวกัน · บอร์ด/เบราว์เซอร์เดียวกัน —
        ต่างแค่ <code class="font-mono text-[#f6c544] bg-[#f6c5441a] px-1.5 py-0.5 rounded">new_install_prompt_erase</code>
        อันหนึ่ง <b class="text-[#ff8a6b]">crash ทั้งเบราว์เซอร์</b> อีกอันทำงานปกติ · กดลองเองได้ทั้งสองข้าง 👇
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mt-9 items-stretch">
      <!-- ═══ ซ้าย: CRASH ═══ -->
      <section class="rounded-2xl border border-[#5c2a26] bg-[#2a1210]/70 p-6 flex flex-col">
        <div class="flex items-center gap-2">
          <span class="text-2xl">💥</span>
          <h2 class="font-display text-lg font-bold text-[#ff8a6b]">erase: true</h2>
          <span class="ml-auto font-display text-[10px] tracking-wide uppercase text-[#ff8a6b] border border-[#5c2a26] rounded-full px-2.5 py-0.5">Crash</span>
        </div>

        <dl class="mt-4 text-[12.5px] font-mono grid grid-cols-[auto_1fr] gap-x-3 gap-y-1.5">
          <dt class="text-[#bd8a8a]">esp-web-tools</dt><dd class="text-[#e8e2d0]">10.2.1</dd>
          <dt class="text-[#bd8a8a]">prompt_erase</dt><dd class="text-[#ff8a6b] font-bold">true</dd>
          <dt class="text-[#bd8a8a]">วิธี flash</dt><dd class="text-[#e8e2d0]">ล้างทั้งชิป 16MB → เขียน</dd>
          <dt class="text-[#bd8a8a]">ระหว่างล้าง</dt><dd class="text-[#e8e2d0]">USB หลุด/ต่อใหม่กลางคัน</dd>
        </dl>

        <div class="mt-4 rounded-lg border border-[#5c2a26] bg-[#1b0b0a]/60 p-3 text-[11.5px] text-[#c9bfa6] leading-relaxed">
          <b class="text-[#ff8a6b]">เกิดอะไรขึ้น:</b> full-chip erase เป็น operation ยาว ระหว่างนั้น
          ESP32-S3 <b>native USB re-enumerate ผิดจังหวะ</b> ตอนเบราว์เซอร์ยังมี transfer ค้าง →
          ชนบั๊ก <code class="font-mono text-[#ff8a6b]">Chrome_IOThread</code> (SIGTRAP / brk 0) →
          <b class="text-[#ff8a6b]">เบราว์เซอร์ตายทั้งตัว</b>
        </div>

        <div class="mt-4 rounded-lg border border-[#7a3a2a] bg-[#3a1512] p-3 text-[11px] text-[#ffb59c] text-center leading-relaxed">
          ⚠️ ปุ่มนี้อาจ crash — race + เฉพาะ Chromium ~149; ถ้า Chrome ใหม่กว่า/patch แล้ว อาจไม่ crash ซึ่งปกติ
        </div>

        <p class="mt-3 text-[11px] leading-relaxed text-[#c9bfa6]">
          กดแล้วไม่ crash = ดี (เบราว์เซอร์ patch แล้ว) — erase:false ปลอดภัยเสมอ
        </p>

        <div class="mt-auto pt-5 flex justify-center">
          <esp-web-install-button manifest={asset("manifests/lesson-erase-true.json")}>
            <button slot="activate" class="px-7 py-3 rounded-[10px] font-display font-bold text-sm text-[#2a1210] bg-gradient-to-br from-[#ff8a6b] to-[#e0533a] cursor-pointer border-0 hover:-translate-y-px transition-transform">
              💥 Flash แบบ erase:true
            </button>
            <span slot="unsupported" class="text-[11px] text-[#ff8a6b]">ใช้ Chrome/Edge บนคอมพิวเตอร์</span>
          </esp-web-install-button>
        </div>
      </section>

      <!-- ═══ ขวา: WORKS ═══ -->
      <section class="rounded-2xl border border-[#2d5c3a] bg-[#0e2a1a]/60 p-6 flex flex-col">
        <div class="flex items-center gap-2">
          <span class="text-2xl">✅</span>
          <h2 class="font-display text-lg font-bold text-[#7fe0a6]">erase: false</h2>
          <span class="ml-auto font-display text-[10px] tracking-wide uppercase text-[#7fe0a6] border border-[#2d5c3a] rounded-full px-2.5 py-0.5">Works</span>
        </div>

        <dl class="mt-4 text-[12.5px] font-mono grid grid-cols-[auto_1fr] gap-x-3 gap-y-1.5">
          <dt class="text-[#8bbd9c]">esp-web-tools</dt><dd class="text-[#e8e2d0]">10.2.1 <span class="text-[#8bbd9c]">(เหมือนกัน!)</span></dd>
          <dt class="text-[#8bbd9c]">prompt_erase</dt><dd class="text-[#7fe0a6] font-bold">false</dd>
          <dt class="text-[#8bbd9c]">วิธี flash</dt><dd class="text-[#e8e2d0]">เขียน offset ตรง ๆ เป็นก้อน</dd>
          <dt class="text-[#8bbd9c]">ระหว่างเขียน</dt><dd class="text-[#e8e2d0]">USB อยู่นิ่ง ไม่หลุด</dd>
        </dl>

        <div class="mt-4 rounded-lg border border-[#2d5c3a] bg-[#081a10]/60 p-3 text-[11.5px] text-[#c9bfa6] leading-relaxed">
          <b class="text-[#7fe0a6]">เกิดอะไรขึ้น:</b> ข้ามการล้าง เขียน firmware ลง offset เป็น chunk เล็ก ๆ
          อุปกรณ์ <b>อยู่นิ่งตลอด</b> ไม่มี re-enumerate ผิดจังหวะ · re-enumerate ครั้งเดียวคือ
          reset ตอนจบหลังปิดพอร์ตแล้ว → <b class="text-[#7fe0a6]">flash ผ่าน + Improv WiFi ทำงาน ไม่ crash</b>
        </div>

        <div class="mt-4 rounded-lg border border-[#2d5c3a] bg-[#0e2a1a] p-3 text-[11px] text-[#a6d9b8] text-center leading-relaxed">
          ✓ ปุ่มนี้ flash ได้จริง ปลอดภัย — เด้ง "Device Dashboard" → กด <b>Install</b> → จอติด
        </div>

        <div class="mt-auto pt-5 flex justify-center">
          <esp-web-install-button manifest={asset("manifests/lesson-erase-false.json")}>
            <button slot="activate" class="px-7 py-3 rounded-[10px] font-display font-bold text-sm text-[#081a10] bg-gradient-to-br from-[#7fe0a6] to-[#3aa06a] cursor-pointer border-0 hover:-translate-y-px transition-transform">
              ✅ Flash แบบ erase:false
            </button>
            <span slot="unsupported" class="text-[11px] text-[#7fe0a6]">ใช้ Chrome/Edge บนคอมพิวเตอร์</span>
          </esp-web-install-button>
        </div>
      </section>
    </div>

    <!-- กลไก + หลักฐาน -->
    <section class="mt-9 rounded-2xl border border-[#22304d] bg-[#0e2145]/60 p-6">
      <h2 class="font-display text-sm font-semibold tracking-wide text-[#4dc4ff]">กลไกจริง (ทำไม erase ถึงพัง)</h2>
      <div class="mt-3 grid md:grid-cols-2 gap-x-8 gap-y-3 text-[12.5px] text-[#c9bfa6] leading-relaxed">
        <p>
          บอร์ด <b class="text-[#e8e2d0]">JC3248W535 (ESP32-S3) ใช้ USB ในตัวชิป</b>
          (USB_SERIAL_JTAG) ไม่ใช่ชิปแปลง USB แยก — พอชิปยุ่งกับ flash หนัก ๆ หรือ reset
          <b class="text-[#e8e2d0]">USB จะหลุดแล้วโผล่ใหม่</b> ที่ฝั่งคอม
        </p>
        <p>
          <b class="text-[#e8e2d0]">Chromium 149</b> (Chrome / Edge / Comet — engine เดียวกัน)
          มีบั๊กที่ thread จัดการ USB/Serial: พออุปกรณ์หลุด<b class="text-[#e8e2d0]">กลางการโอนที่ค้างอยู่</b>
          มันชน assertion แล้ว <b class="text-[#ff8a6b]">crash ทั้ง process</b>
        </p>
      </div>
      <p class="mt-4 text-[12px] text-[#8a9bbd] leading-relaxed">
        <b class="text-[#c9bfa6]">erase = trigger:</b> full-chip erase สร้างจังหวะที่ USB หลุดตอน transfer ค้าง →
        โดนบั๊ก · <b class="text-[#c9bfa6]">no-erase = รอด:</b> เขียนนิ่ง ๆ อุปกรณ์ไม่หลุดจนเขียนเสร็จ
      </p>

      <div class="mt-5 grid md:grid-cols-3 gap-3 text-[11px]">
        <div class="rounded-lg border border-[#1a2838] bg-[#0b1b39]/60 p-3">
          <div class="font-display text-[10px] tracking-wide uppercase text-[#6f8ba0]">Crash signature</div>
          <div class="font-mono text-[#c9bfa6] mt-1">Chrome_IOThread · EXC_BREAKPOINT (brk 0)<br />org.libusb.device-hotplug</div>
        </div>
        <div class="rounded-lg border border-[#1a2838] bg-[#0b1b39]/60 p-3">
          <div class="font-display text-[10px] tracking-wide uppercase text-[#6f8ba0]">พิสูจน์แล้ว</div>
          <div class="text-[#c9bfa6] mt-1">Mac + JC3248W535 + Chromium 149 · A/B test เครื่องเดียวกัน</div>
        </div>
        <div class="rounded-lg border border-[#1a2838] bg-[#0b1b39]/60 p-3">
          <div class="font-display text-[10px] tracking-wide uppercase text-[#6f8ba0]">ตรงงานวิจัย</div>
          <div class="text-[#c9bfa6] mt-1">esp-web-tools #545/#608 — "upload+erase crashes, upload-only works"</div>
        </div>
      </div>
    </section>

    <div class="mt-6 rounded-xl border border-[#22304d] bg-[#0b1b39]/50 p-4 text-[12px] text-[#c9bfa6]">
      <b class="text-[#f6c544] font-display">TL;DR สำหรับทีม:</b>
      ESP32-S3 native USB + web flash → ตั้ง
      <code class="font-mono text-[#f6c544] bg-[#f6c5441a] px-1.5 py-0.5 rounded">new_install_prompt_erase: false</code>
      ในทุก manifest เสมอ · esp-web-tools เวอร์ชันไหนก็ได้ · แล้วจะไม่ crash
    </div>

    <footer class="mt-10 pt-5 border-t border-[#2a3a5c] text-center text-[11px] text-[#8a9bbd]">
      <span class="block text-[#5f7091]">🤖 หน้านี้สร้างและดูแลโดย kru32-oracle (AI) — ไม่ใช่มนุษย์</span>
    </footer>
  </div>
</Base>
