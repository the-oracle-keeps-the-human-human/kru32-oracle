---
import Base from "../layouts/Base.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title="ตั้งค่า WiFi — Kru32 Oracle" description="ต่อ WiFi ให้บอร์ด JC3248W535 ที่ flash แล้ว ผ่าน Improv Serial">
  <div class="relative max-w-[640px] mx-auto px-6 py-10 pb-16">
    <a href={`${base}/`} class="font-display text-[11px] text-[#f6c544] hover:underline">← กลับหน้ารวมบท</a>

    <header class="mt-6 text-center">
      <div class="font-display text-[13px] italic text-[#f6c544]">Kru32 Oracle</div>
      <h1 class="font-display text-[2rem] font-bold text-[#f4efe0] mt-1 [text-shadow:0_2px_28px_rgba(246,197,68,.3)]">
        ตั้งค่า WiFi
      </h1>
      <p class="text-[#c9bfa6] text-sm mt-3">
        สำหรับบอร์ด JC3248W535 ที่ <b class="text-[#f4efe0]">flash แล้ว</b> — ต่อ WiFi ผ่าน USB
        โดยไม่ต้องแก้ YAML
      </p>
    </header>

    <!-- Step 1: เลือกพอร์ต -->
    <div class="mt-8 flex flex-col items-center gap-3">
      <div class="flex items-center gap-2 mb-1">
        <span class="font-display font-bold text-[#f6c544] text-lg">1</span>
        <span class="text-[13px] text-[#c9bfa6]">เสียบ USB-C แล้วเลือกพอร์ตของบอร์ด</span>
      </div>
      <button
        id="pick-port"
        class="kru-pulse w-full max-w-[320px] py-3 rounded-[10px] font-display font-bold text-sm tracking-wide text-[#1a1204] bg-gradient-to-br from-[#f6c544] to-[#e0a838] hover:-translate-y-px transition-transform cursor-pointer border-0"
      >
        🔌 เลือกพอร์ต Serial
      </button>
      <p id="port-status" class="text-[12px] text-[#8a9bbd] text-center max-w-[380px]"></p>
    </div>

    <!-- Step 2: ต่อ WiFi (ซ่อนไว้จนกว่าจะเลือกพอร์ตแล้ว) -->
    <div id="wifi-step" class="hidden mt-6 flex flex-col items-center gap-3">
      <div class="flex items-center gap-2 mb-1">
        <span class="font-display font-bold text-[#f6c544] text-lg">2</span>
        <span class="text-[13px] text-[#c9bfa6]">ใส่ชื่อ WiFi + รหัสผ่าน</span>
      </div>
      <improv-wifi-serial-launch-button>
        <button
          slot="activate"
          class="kru-pulse w-full max-w-[320px] py-3 rounded-[10px] font-display font-bold text-sm tracking-wide text-[#1a1204] bg-gradient-to-br from-[#4dc4ff] to-[#2a88cc] hover:-translate-y-px transition-transform cursor-pointer border-0"
        >
          📶 ต่อ WiFi ให้บอร์ด
        </button>
        <span slot="unsupported" class="block mt-2 max-w-[380px] text-[11px] text-[#ff8a6b] text-center leading-relaxed">
          เบราว์เซอร์นี้ไม่รองรับ Improv<br />ใช้ Chromium (Chrome / Edge / Comet) บนคอมพิวเตอร์
        </span>
      </improv-wifi-serial-launch-button>
      <p class="text-[11px] text-[#8a9bbd] text-center max-w-[380px]">
        เลือกพอร์ตเดิมอีกครั้ง → ใส่ชื่อ WiFi + รหัสผ่าน → บอร์ดต่อเน็ตเอง
      </p>
    </div>

    <script>
      const pickBtn = document.getElementById("pick-port");
      const portStatus = document.getElementById("port-status");
      const wifiStep = document.getElementById("wifi-step");

      if (!("serial" in navigator)) {
        if (pickBtn) pickBtn.textContent = "❌ เบราว์เซอร์ไม่รองรับ Serial";
        if (pickBtn) pickBtn.disabled = true;
        if (portStatus) portStatus.innerHTML = 'ใช้ <b style="color:#f4efe0">Chrome / Edge / Comet</b> บนคอมพิวเตอร์';
      } else if (pickBtn) {
        pickBtn.addEventListener("click", async () => {
          try {
            const port = await navigator.serial.requestPort();
            await port.open({ baudRate: 115200 });
            const info = port.getInfo();
            const label = info.usbVendorId
              ? `USB ${info.usbVendorId.toString(16)}:${info.usbProductId.toString(16)}`
              : "Serial port";
            await port.close();

            if (portStatus) portStatus.innerHTML = `✅ เจอบอร์ดแล้ว — <b style="color:#7fe0a6">${label}</b>`;
            pickBtn.textContent = "✅ เลือกพอร์ตแล้ว";
            pickBtn.classList.remove("from-[#f6c544]", "to-[#e0a838]", "text-[#1a1204]");
            pickBtn.classList.add("from-[#2d5c3a]", "to-[#1a4028]", "text-[#7fe0a6]", "border", "border-[#2d5c3a]");

            if (wifiStep) {
              wifiStep.classList.remove("hidden");
              wifiStep.classList.add("flex");
              wifiStep.scrollIntoView({ behavior: "smooth", block: "center" });
            }
          } catch (e) {
            if (portStatus) portStatus.textContent = "⚠️ " + (e instanceof Error ? e.message : String(e));
          }
        });
      }
    </script>

    <div class="mt-6 rounded-lg border border-[#2a3a5c] bg-[#0b1b39]/60 p-4 text-[11px] text-[#8a9bbd] leading-relaxed">
      <b class="text-[#c9bfa6]">ทำไมแยกจากปุ่ม Flash?</b><br />
      ตอน flash เสร็จ บอร์ด reset → USB re-enumerate ถ้าตั้ง WiFi ตอนนั้นทันที Chromium
      (Chrome/Edge/Comet) จะ crash หน้านี้จึงทำ WiFi <b class="text-[#c9bfa6]">แยกทีหลัง</b> ตอนบอร์ดนิ่งแล้ว
      — ไม่มี re-enumerate = ไม่ crash · ถ้า Chrome ยังมีปัญหา ลอง <b class="text-[#c9bfa6]">Edge</b>
    </div>

    <footer class="mt-10 pt-5 border-t border-[#2a3a5c] text-center text-[11px] text-[#8a9bbd]">
      <span class="block text-[#5f7091]">🤖 หน้านี้สร้างและดูแลโดย Kru32 Oracle (AI) — ไม่ใช่มนุษย์</span>
    </footer>
  </div>
</Base>
